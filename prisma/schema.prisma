// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  role         String       @default("student") // admin, teacher, student
  avatar       String?
  bio          String?
  createdAt    DateTime     @default(now())
  isApproved   Boolean      @default(false)
  isActive     Boolean      @default(true)
  enrollments  Enrollment[]
  coursesTaught Course[]
  submissions  Submission[]
}

model Course {
  id               String       @id @default(cuid())
  title            String
  description      String
  shortDescription String
  thumbnail        String?
  teacherId        String
  teacherName      String
  category         String
  tags             String?      // Comma-separated or JSON
  learningOutcomes String?      // Comma-separated or JSON
  capacity         Int          @default(30)
  enrolled         Int          @default(0)
  status           String       @default("draft") // published, draft, pending
  rating           Float?
  level            String       // beginner, intermediate, advanced
  startDate        DateTime?
  endDate          DateTime?
  createdAt        DateTime     @default(now())
  
  teacher          User         @relation(fields: [teacherId], references: [id])
  modules          Module[]
  assignments      Assignment[]
  enrollments      Enrollment[]
  materials        Material[]
  announcements    Announcement[]
}

model Module {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  order       Int
  
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  units       Unit[]
  materials   Material[]
}

model Unit {
  id          String   @id @default(cuid())
  moduleId    String
  title       String
  type        String   // lesson, quiz, activity
  duration    String
  isCompleted Boolean  @default(false) // Note: In a real app this should be a many-to-many through User progress
  
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model Material {
  id          String   @id @default(cuid())
  courseId    String
  moduleId    String
  title       String
  type        String   // pdf, video, link, document
  url         String
  size        String?
  uploadedAt  DateTime @default(now())

  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model Announcement {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  content     String
  authorName  String
  createdAt   DateTime @default(now())

  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id          String   @id @default(cuid())
  studentId   String
  courseId    String
  enrolledAt  DateTime @default(now())
  status      String   @default("active") // active, completed, dropped
  progress    Int      @default(0)
  grade       Float?

  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Assignment {
  id            String   @id @default(cuid())
  courseId      String
  title         String
  description   String
  deadline      DateTime
  maxScore      Int
  status        String   @default("active") // active, completed, overdue
  createdAt     DateTime @default(now())

  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  submissions   Submission[]
}

model Submission {
  id            String   @id @default(cuid())
  assignmentId  String
  studentId     String
  studentName   String
  submittedAt   DateTime?
  fileName      String?
  comment       String?
  status        String   @default("submitted") // submitted, graded, late
  score         Float?
  feedback      String?

  assignment    Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student       User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
}
